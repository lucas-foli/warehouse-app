VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional multi-tenant helpers
VITE_TENANT_SLUG=
VITE_DEFAULT_TENANT_SLUG=default
VITE_BASE_DOMAIN=

# Supabase Auth redirect configuration (dashboard, NOT env):
# In Supabase → Auth → URL Configuration, add a wildcard entry to
# "Additional Redirect URLs" so reset-password / magic-link emails can
# return the user to their tenant subdomain:
#     https://*.yourdomain.com/
#     https://*.yourdomain.com/**
# Without this, Supabase rewrites the redirect to the Site URL and the
# tenant slug is lost. Users who land on the apex while signed in are
# shown an explicit workspace picker — there is no automatic forward.

VITE_LOOKER_EMBED_URL=

# n8n webhook URL is now configured as a Supabase Edge Function secret (N8N_WEBHOOK_URL)
# It is NOT exposed to the client. Set it via: supabase secrets set N8N_WEBHOOK_URL=https://...

# Comma-separated list of allowed origins for the proxy-webhook Edge Function CORS policy.
# Set via: supabase secrets set ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
# ALLOWED_ORIGINS=
